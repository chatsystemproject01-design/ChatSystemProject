# ==== MÔI TRƯỜNG CHẠY SERVER ====
FLASK_APP=run.py
FLASK_ENV=production
PORT=8080

# ==== SECURITY / BẢO MẬT ====
# QUAN TRỌNG: Hãy tạo một chuỗi ngẫu nhiên mới cho môi trường production thay vì dùng chung với local
SECRET_KEY=your_production_secret_key_here
JWT_SECRET_KEY=your_production_jwt_secret_key_here
AES_SECRET_KEY=ChatSystem
BCRYPT_LOG_ROUNDS=14

# ==== CƠ SỞ DỮ LIỆU (DATABASE) ====
# Đặt URI PostgreSQL của bạn tại đây (ví dụ: host trên Neon.tech, Supabase)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# ==== CẤU HÌNH WEBSOCKET ====
# Production sử dụng Eventlet thông qua server Gunicorn
SOCKETIO_ASYNC_MODE=eventlet

# ==== HỆ THỐNG GỬI EMAIL (SMTP) ====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
# Khuyến nghị dùng "App Password" đối với Gmail, không dùng password chính
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# ==== EXTERNAL STORAGE / CÚ VỌ (SUPABASE) ====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# ==== TRÍ TUỆ NHÂN TẠO (AI MODEL) ====
API_KEY=your_openrouter_api_key_here
API_URL=https://openrouter.ai/api/v1/chat/completions
MODEL=nvidia/nemotron-3-super-120b-a12b:free
